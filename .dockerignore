node_modules
frontend/node_modules
# frontend/.next is INCLUDED in the build context — we prebuild on
# the host (arm64 native, ~5 min) and copy the artifacts in, instead
# of running `npm run build` inside the linux/amd64 QEMU-emulated
# stage. The Next.js compile under QEMU has been observed to hang
# 25+ min on Apple Silicon. The .next bundle is portable JS + static
# assets, so an arm64-built artifact runs fine on the amd64 server.
frontend/.next.broken*
# .next/cache is the webpack build cache (~150MB) — NOT needed by `next
# start` at runtime; excluding it keeps the build context tiny so it
# uploads reliably on a slow/flaky link.
frontend/.next/cache
__pycache__
*.pyc
# chroma_db is a local vector index — not used by the server build.
chroma_db/
.git
.playwright-cli/
.playwright-mcp/
.env
data/
output/
uploads/
.superpowers/
dev_dataset/
tests/
docs/
*.md
!compliance_os/**/*.md
!compliance_os/professional_search/personas_data/**
