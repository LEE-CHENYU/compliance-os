# Copy to .env and fill in your values
APP_ENV=dev
# Optional: Postgres for Neon / production-grade persistence
# DATABASE_URL=postgresql+psycopg://user:password@host/database?sslmode=require
# DATABASE_DIRECT_URL=postgresql+psycopg://user:password@host/database?sslmode=require

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6-20250527
# Optional: cheaper model for document extraction (defaults to Haiku 4.5)
# ANTHROPIC_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Optional OpenAI fallback
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4.1-mini
# Optional voice-only override
# VOICE_LLM_PROVIDER=openai
# OPENAI_VOICE_MODEL=gpt-5.4
# Optional server-side Vapi key for future backend integrations
# VAPI_PRIVATE_KEY=your-vapi-private-key-here

# Optional: Gmail API (for email integration)
# GOOGLE_OAUTH_CREDENTIALS=path/to/credentials.json
